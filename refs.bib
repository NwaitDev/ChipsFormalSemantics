@inbook{doi:https://doi.org/10.1002/047166880X.ch3,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {Z-Transforms and Transfer Functions},
booktitle = {Feedback Control of Computing Systems},
chapter = {3},
pages = {65-109},
doi = {https://doi.org/10.1002/047166880X.ch3},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch3},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch3},
year = {2004},
keywords = {Z-transform, difference equation, transfer function, stability, steady-state gain, system order, transient response, pole},
abstract = {Summary In this chapter we develop the tools for analyzing the statics and dynamics of input-output relationships in discrete, time-invariant, linear systems. Our fundamental tool is the Z-transform, a simple but powerful mathematical technique that is used throughout the remainder of the book. Z-transforms are used to solve difference equations (such as those in Chapter 2), to infer steady-state properties of signals, to assess the stability of systems, and to analyze transient response.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch4,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {System Modeling with Block Diagrams},
booktitle = {Feedback Control of Computing Systems},
chapter = {4},
pages = {111-128},
doi = {https://doi.org/10.1002/047166880X.ch4},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch4},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch4},
year = {2004},
keywords = {block diagram, cascaded control, feedforward transfer function, loop transfer function, block diagram restructuring},
abstract = {Summary The key to a successful application of control theory is modeling. Chapter 2 describes how to model individual components using difference equations, and Chapter 3 details how to analyze these models using Z-transforms. This chapter discusses the use of block diagrams to model systems that consist of many components. We discuss the elements of a block diagram and principles for modeling systems using these elements. Also addressed is how to use block diagrams to obtain the transfer function of a system, thereby enabling the analysis of bounded-input, bounded-output (BIBO) stability and other properties using the techniques presented in Chapter 3.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch5,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {First-Order Systems},
booktitle = {Feedback Control of Computing Systems},
chapter = {5},
pages = {129-164},
doi = {https://doi.org/10.1002/047166880X.ch5},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch5},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch5},
year = {2004},
keywords = {steady-state response, transient response, superposition property, initial condition response, impulse response, step response, settling time, overshoot},
abstract = {Summary This chapter presents techniques for analyzing first-order systems. First-order systems are of interest for several reasons: (a) many real world systems (e.g., the IBM Lotus Domino Server and the Apache HTTP Server) can be modeled as first-order systems; (b) several approximations used in control design are based on first-order systems; and (c) first-order systems are simple and hence have pedagogical value. The chapter addresses both the statics and dynamics of first-order systems, with particular emphasis on dynamics. The properties studied are stability, steady-state output, settling time, and maximum overshoot. Where possible, simple formulas are used to communicate the underlying theory, and various examples are used to demonstrate the application of the theory to computing systems.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch6,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {Higher-Order Systems},
booktitle = {Feedback Control of Computing Systems},
chapter = {6},
pages = {165-199},
doi = {https://doi.org/10.1002/047166880X.ch6},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch6},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch6},
year = {2004},
keywords = {multiple poles, real poles, complex poles, zeros, dominant pole analysis, settling time, overshoot},
abstract = {Summary The presence of multiple poles and zeros makes it more difficult to estimate settling times and maximum overshoot. Thus, we develop simple approximations for these metrics. For example, the approximation for settling time is based on a dominant pole analysis that uses the results for first-order systems. Another complication in higher-order systems is that poles may be complex, a situation that indicates an oscillatory response to common inputs such as the impulse and step.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch7,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {State-Space Models},
booktitle = {Feedback Control of Computing Systems},
chapter = {7},
pages = {201-241},
doi = {https://doi.org/10.1002/047166880X.ch7},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch7},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch7},
year = {2004},
keywords = {state-space model, state vector, MIMO, transfer function matrix, control canonical form, controllability, observability},
abstract = {Summary This chapter introduces state-space models for describing system dynamics. State-space models provide a scalable approach to modeling MIMO systems – those with multiple inputs and outputs. We define for state-space models many of the familiar concepts from transfer function modeling, such as poles and transfer functions. Further, it is shown how many of the techniques and results covered in earlier chapters can apply to state-space models as well, such as stability and dominant pole analysis. The concepts of controllability and observability, which are unique to state-space models are presented.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch8,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {Proportional Control},
booktitle = {Feedback Control of Computing Systems},
chapter = {8},
pages = {243-291},
doi = {https://doi.org/10.1002/047166880X.ch8},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch8},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch8},
year = {2004},
keywords = {proportional control, control law, feedback control gain, closed loop system, root locus, pole placement},
abstract = {Summary This chapter describes proportional control, the simplest form of feedback control, and analyzes its characteristics in computing systems. We use the simplicity of proportional control as a way to provide insights into feedback control systems, including detailed examples with step-by-step simulations. The chapter introduces the concept of pole placement design, a technique that views control design as constructing systems with desired closed loop poles. Other topics covered in this chapter include: assessing controller quality; controlling a first-order system with measurement delays and a moving average filter; and root locus analysis.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch9,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {PID Controllers},
booktitle = {Feedback Control of Computing Systems},
chapter = {9},
pages = {293-335},
doi = {https://doi.org/10.1002/047166880X.ch9},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch9},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch9},
year = {2004},
keywords = {integral control, derivative control, PI control, PID control, pole placement, root locus, CHR design method, bump test},
abstract = {Summary This chapter introduces the integral and derivative control actions. Integral control can drive the steady-state error to zero, whereas derivative control provides a way to respond quickly. Also addressed are various combinations of proportional, integral, and derivative control actions, especially the PID controller (which includes all three). Various approaches to controller design are discussed, including pole placement, root locus and an empirical heuristic known as the CHR design method.}
}
@inbook{doi:https://doi.org/10.1002/047166880X.ch10,

publisher = {John Wiley & Sons, Ltd},
isbn = {9780471668800},
title = {State-Space Feedback Control},
booktitle = {Feedback Control of Computing Systems},
chapter = {10},
pages = {337-374},
doi = {https://doi.org/10.1002/047166880X.ch10},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/047166880X.ch10},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/047166880X.ch10},
year = {2004},
keywords = {state-space models, matrix models, multiple-output (MIMO) systems, state feedback, pole placement, dynamic state feedback, linear quadratic regulation (LQR), optimal control},
abstract = {Summary This chapter describes several approaches to the design of feedback controllers for systems modeled in state space form, including multiple-input multiple-output (MIMO) systems. Static state feedback is a multidimensional extension of proportional control, and dynamic state feedback can be viewed as the state-space analog to PI (proportional integral) control. Pole placement design determines the poles needed to achieve the desired closed-loop properties and then computes the feedback gains required. Linear quadratic regulation (LQR) employs an optimization technique that parameterizes the trade-off between control error and control effort.}
}


